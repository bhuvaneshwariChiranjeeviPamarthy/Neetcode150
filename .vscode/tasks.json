{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Current C++ File",
      "type": "shell",
      "command": "g++ -std=c++17 -O2 \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
